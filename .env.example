# ========== DATABASE ==========
DATABASE_URL="postgresql://user:password@localhost:5432/agent"
MONGODB_URL="mongodb://localhost:27017/agent-agenda"

# ========== REDIS ==========
REDIS_URL="redis://localhost:6379"

# ========== OPENAI ==========
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-5-nano"

# ========== CHATWOOT ==========
CHATWOOT_URL="https://chatwoot.example.com"
CHATWOOT_API_TOKEN="token..."
CHATWOOT_ACCOUNT_ID="1"

# ========== UAZAPI (WhatsApp) ==========
UAZAPI_KEY="key..."
UAZAPI_URL="https://api.uazapi.com"

# ========== SLACK ==========
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."
SLACK_BOT_TOKEN="xoxb-..."

# ========== SERVER ==========
PORT=3030
NODE_ENV="development"
LOG_LEVEL="info"

# ========== AGENTS CONFIG ==========
FOLLOW_UP_DELAY_HOURS=24
COLD_STORAGE_DAYS=7
MIN_INTENT_SCORE=0.7

# ========== AGENT PERSONA / RESPOSTAS ==========
AGENT_AUTO_REPLY_ENABLED=true
AGENT_COMPANY_NAME="Sua Empresa"
AGENT_OBJECTIVE="Qualificar leads e avançar para reunião ou proposta."
AGENT_TONE="consultivo e cordial"
AGENT_LANGUAGE="português do Brasil"
AGENT_MAX_REPLY_CHARS=420
AGENT_CONFIG_PATH="./data/agent-config.json"

# ========== ADMIN CONFIG PANEL (opcional) ==========
# Defina para proteger /api/admin/agent-config
ADMIN_CONFIG_TOKEN=
