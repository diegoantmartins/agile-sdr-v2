generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id             String        @id @default(uuid())
  name           String?
  phone          String        @unique
  email          String?
  company        String?
  profile        String?
  country        String        @default("BR")
  lastHumanOwner String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  budgets        Budget[]
  opportunities  Opportunity[]

  @@index([phone])
}

model Budget {
  id            String        @id @default(uuid())
  externalId    String?
  contactId     String
  productName   String?
  budgetValue   Decimal?
  budgetDate    DateTime
  projectName   String?
  city          String?
  status        String?
  notes         String?
  source        String        @default("legacy_budget")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  contact       Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]

  @@index([contactId])
  @@index([budgetDate])
}

model Opportunity {
  id                 String    @id @default(uuid())
  budgetId           String
  contactId          String
  stage              String    @default("reactivation_pending")
  temperature        String    @default("warm")
  priorityScore      Int       @default(0)
  nextFollowupAt     DateTime?
  lastOutreachAt     DateTime?
  lastResponseAt     DateTime?
  ownerType          String    @default("agent")
  humanOwner         String?
  reactivationReason String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  messages           Message[]
  budget             Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  contact            Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([budgetId])
  @@index([contactId])
  @@index([stage])
  @@index([priorityScore])
}

model Message {
  id                String       @id @default(uuid())
  opportunityId     String?
  direction         String?
  channel           String       @default("whatsapp")
  content           String
  sentAt            DateTime?    @default(now())
  deliveryStatus    String?
  intentDetected    String?
  rawPayload        Json?
  createdAt         DateTime     @default(now())
  chatwootMessageId String?      @unique
  isAiGenerated     Boolean      @default(false)
  leadId            String?
  syncError         String?
  syncStatus        SyncStatus?
  tenantId          String?
  type              String?
  lead              ActiveLead?  @relation("LeadMessages", fields: [leadId], references: [id], onDelete: Cascade)
  opportunity       Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@index([leadId])
  @@index([createdAt])
}

model CampaignRule {
  id                 String   @id @default(uuid())
  name               String
  minDaysSinceBudget Int      @default(7)
  maxDaysSinceBudget Int?
  allowedProducts    String[] @default([])
  cooldownDays       Int      @default(15)
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model JobLog {
  id             String    @id @default(uuid())
  jobType        String
  status         String
  processedCount Int       @default(0)
  error          String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  duration       Int?
  leadsProcessed Int       @default(0)
  leadsSkipped   Int       @default(0)

  @@index([jobType])
  @@index([startedAt])
}

model SystemHealth {
  id             String   @id @default(uuid())
  uazapiStatus   String   @default("unknown")
  chatwootStatus String   @default("unknown")
  openaiStatus   String   @default("unknown")
  lastChecked    DateTime @default(now())

  @@index([lastChecked])
}

model ActiveLead {
  id                String      @id @default(uuid())
  tenantId          String
  phone             String
  name              String
  email             String?
  company           String?
  source            String      @default("whatsapp")
  campaignId        String?
  metadata          Json?
  score             Int         @default(0)
  status            LeadStatus  @default(TRIAGE)
  intentClassified  IntentType?
  conversionStage   String?
  messageCount      Int         @default(0)
  lastMessageAt     DateTime?
  chatwootContactId String?
  chatwootConvId    String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  messages          Message[]   @relation("LeadMessages")
  notes             Note[]

  @@unique([tenantId, phone], name: "tenant_phone_unique")
  @@index([tenantId])
  @@index([status])
  @@index([score])
}

model ColdLead {
  id               String     @id @default(uuid())
  tenantId         String
  originalLeadId   String
  phone            String
  name             String
  email            String?
  company          String?
  lastScore        Int
  lastStatus       LeadStatus
  freezeReason     String
  conversationData Json?
  createdAt        DateTime   @default(now())

  @@index([tenantId])
}

model GovernanceAudit {
  id        String   @id @default(uuid())
  tenantId  String
  action    String
  actor     String
  success   Boolean
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([action])
}

model Note {
  id        String     @id @default(uuid())
  leadId    String
  content   String
  type      String     @default("general")
  createdAt DateTime   @default(now())
  lead      ActiveLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model ConversationMetric {
  id               String   @id @default(uuid())
  leadId           String
  messageCount     Int      @default(0)
  userMessageCount Int      @default(0)
  aiMessageCount   Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([leadId])
}

enum JobStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

enum LeadStatus {
  TRIAGE
  FOLLOW_UP
  HOT
  HUMAN_REQUIRED
  ARCHIVED
}

enum IntentType {
  BUY_NOW
  SUPPORT
  TRIAGE
  HANDOFF_HUMANO
  SERVICO_FECHADO
  LICITACAO_PERDIDA
  OBRA_SEM_FRENTE
  FOLLOW_UP_NORMAL
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}
